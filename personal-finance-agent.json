        "jsCode": "const html = $('Gmail Trigger').first().json.html;\nconst match = html.match(/data:image\\/[^;]+;base64,([^\"]+)/);\nconst imageBase64 = match ? match[1] : '';\nreturn [{ json: { imageBase64 } }];"
