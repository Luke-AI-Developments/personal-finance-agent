    {
      "parameters": {
        "jsCode": "const text = $('HTTP Request').first().json.responses[0].textAnnotations[0].description;\n\nconst dateMatch = text.match(/(\\d{2}\\/\\d{2}\\/\\d{4})/);\nconst payslipDate = dateMatch ? dateMatch[1] : '';\n\nlet netPay = '';\nconst netPayIndex = text.indexOf('Net Pay');\nif (netPayIndex !== -1) {\n  const remaining = text.substring(netPayIndex);\n  const amounts = [...remaining.matchAll(/£([\\d,]+\\.\\d{2})/g)];\n  netPay = amounts.length > 0 ? amounts[amounts.length - 1][1] : '';\n}\n\nfunction lastFridayOfMonth(year, month) {\n  const lastDay = new Date(year, month + 1, 0);\n  const dow = lastDay.getDay();\n  const daysBack = dow >= 5 ? dow - 5 : dow + 2;\n  return new Date(year, month, lastDay.getDate() - daysBack);\n}\n\nconst [currDay, currMonth, currYear] = payslipDate.split('/');\nconst currDate = new Date(`${currYear}-${currMonth}-${currDay}`);\nconst nextMonth = new Date(parseInt(currYear), parseInt(currMonth), 1);\nconst nextPayDate = lastFridayOfMonth(nextMonth.getFullYear(), nextMonth.getMonth());\nconst weeksToNextPay = Math.round((nextPayDate - currDate) / (1000 * 60 * 60 * 24 * 7));\n\nconst existingRows = $('Get row(s) in sheet').all().length;\nconst rowNum = existingRows + 2;\nconst prevRow = rowNum - 1;\n\nconst walletMoney = `=IF(B${rowNum}=4,(C${rowNum}/100*35/4),(C${rowNum}/100*45/5))`;\nconst caBalanceAa = `=IF(B${rowNum}=4,N${rowNum}-D${rowNum}-E${rowNum}-P${rowNum}-R${rowNum}-H${rowNum}-L${rowNum}-AH${rowNum},N${rowNum}-D${rowNum}-R${rowNum}-E${rowNum}-H${rowNum}-L${rowNum}-AH${rowNum})`;\nconst goldValue = `=W${rowNum}*V${rowNum}`;\nconst valueDiff = `=X${rowNum}-X${prevRow}`;\nconst netWorth = `=X${rowNum}+T${rowNum}+Q${rowNum}+O${rowNum}`;\nconst nwChange = `=Z${rowNum}-Z${prevRow}`;\nconst allRows = $('Get row(s) in sheet').all();\nconst lastRow = allRows[allRows.length - 1].json;\nconst Subs = lastRow['subs'];\nconst bills = lastRow['bills'];\nconst debt = lastRow['debt'];\nconst repayment = lastRow['repayment'];\nconst JAcontribution = lastRow['JA contribution'];\nconst ccbalance = lastRow['cc balance'];\nconst creditscore = lastRow['credit score'];\nconst addpension = lastRow['add pension'];\nconst pensionpot = lastRow['pension pot'];\nconst lisacon = lastRow['lisa con'];\nconst isacon = lastRow['isa con'];\nconst gold = allRows[allRows.length - 1].json['gold'];\nlet pensionContribution = '';\nconst nobMatch = text.match(/NOB UK 1\\s*[\\n\\r]+[£E]([\\d,]+\\.\\d{2})/);\nif (nobMatch) pensionContribution = parseFloat(nobMatch[1].replace(/,/g, '')).toFixed(2);\nreturn [{ json: { payslipDate, netPay, weeksToNextPay, walletMoney, caBalanceAa, goldValue, valueDiff, netWorth, nwChange, gold, pensionContribution, isacon, pensionpot, addpension, creditscore, ccbalance, JAcontribution, repayment, debt, bills, Subs, lisacon } }];"
      },
